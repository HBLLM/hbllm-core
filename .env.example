# ─────────────────────────────────────────────────────────────────────────────
# HBLLM Core — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to '.env' and modify as needed. The application will
# automatically load these variables using python-dotenv.

# ── Environment ──────────────────────────────────────────────────────────────
HBLLM_ENV=development

# ── Persistence (Asyncpg / Redis) ────────────────────────────────────────────
# If omitted, the system falls back to local SQLite/JSON storage in HBLLM_DATA_DIR
HBLLM_DATABASE_URL=postgresql://hbllm:hbllm_password@localhost:5432/hbllm_brain
HBLLM_REDIS_URL=redis://localhost:6379/0

# ── Storage & Configuration ──────────────────────────────────────────────────
# Directory for local fallback storage, models, and file artifacts
HBLLM_DATA_DIR=./data

# Path to cluster routing configuration
HBLLM_CLUSTER_CONFIG=./config/cluster.yaml

# ── Security & Authentication ────────────────────────────────────────────────
HBLLM_ADMIN_USER=admin
HBLLM_ADMIN_PASS=admin_password_change_me
HBLLM_SECRET_KEY=super-secret-key-change-me
HBLLM_JWT_SECRET=super-secret-jwt-change-me
HBLLM_CSRF_SECRET=super-secret-csrf-change-me
HBLLM_CORS_ORIGINS=http://localhost:3000,http://localhost:8000
